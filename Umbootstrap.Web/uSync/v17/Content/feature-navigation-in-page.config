  <Properties>
    <contentGrid>
      <Value><![CDATA[{
  "contentData": [
    {
      "contentTypeKey": "0708fc2f-92f1-4efc-a9d1-a755f66e6845",
      "key": "a1111111-1111-4111-8111-111111111105",
      "values": []
    },
    {
      "contentTypeKey": "1e6ac523-7122-4994-9f51-7ca67065222a",
      "key": "a1111111-1111-4111-8111-111111111101",
      "values": []
    },
    {
      "contentTypeKey": "dfab01ba-2429-4be9-a894-3c6c4c49df94",
      "key": "a1111111-1111-4111-8111-111111111103",
      "values": []
    },
    {
      "contentTypeKey": "f170b29c-338f-4ab8-a5c4-f72c90826f69",
      "key": "a1111111-1111-4111-8111-111111111115",
      "values": []
    },
    {
      "contentTypeKey": "d5bfea49-0733-48ff-9ee0-d83c01a4cbf4",
      "key": "a1111111-1111-4111-8111-111111111109",
      "values": [
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Introduction"
        },
        {
          "alias": "featurePropertyFeatureDescription",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "An overview of the Navigation - In Page feature and what it provides to content editors and site visitors"
        },
        {
          "alias": "richTextContent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Cp\u003EThe Navigation - In Page feature creates a sticky sidebar navigation that automatically links to features on the current page. As the visitor scrolls through the content, Bootstrap ScrollSpy highlights the currently visible section in the navigation list, providing a clear sense of position within the page.\u003C/p\u003E\u003Cp\u003EThis is particularly useful on longer pages where content is broken into distinct sections. Rather than forcing visitors to scroll blindly, the in-page navigation gives them an overview of what the page contains and lets them jump directly to the section they need.\u003C/p\u003E\u003Cp\u003EOnly features that have a \u003Cstrong\u003EFeature Title\u003C/strong\u003E set will appear in the navigation picker. Features without a title \u2014 such as standalone images, the navigation block itself, or the page title and description block \u2014 are automatically excluded from the picker. This keeps the navigation clean and focused on meaningful, titled content sections.\u003C/p\u003E"
          }
        }
      ]
    },
    {
      "contentTypeKey": "d5bfea49-0733-48ff-9ee0-d83c01a4cbf4",
      "key": "a1111111-1111-4111-8111-111111111111",
      "values": [
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "How It Differs from Table of Contents"
        },
        {
          "alias": "featurePropertyFeatureDescription",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Editor-controlled navigation vs automatic generation"
        },
        {
          "alias": "richTextContent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Cp\u003EThe In-Page Navigation and Table of Contents features both link to sections within a page, but they work very differently.\u003C/p\u003E\u003Cp\u003EThe In-Page Navigation is \u003Cstrong\u003Eeditor-driven\u003C/strong\u003E: the content editor uses a Contentment picker to choose exactly which blocks appear in the navigation and in what order. The picker can select blocks from \u003Cstrong\u003Eany area on the page\u003C/strong\u003E, not just the area the navigation sits in. This gives editors full control over what appears and what doesn\u0027t.\u003C/p\u003E\u003Cp\u003EThe Table of Contents is \u003Cstrong\u003Eautomatic\u003C/strong\u003E: it discovers all titled feature blocks in \u003Cstrong\u003Eits own area only\u003C/strong\u003E and lists them in the order they appear. There is no picker and no way to exclude individual blocks \u2014 if a block has a Feature Title, it appears in the TOC.\u003C/p\u003E\u003Cp\u003EThe In-Page Navigation is designed for the \u003Cstrong\u003Eright sidebar\u003C/strong\u003E as a sticky card on desktop and an offcanvas bottom bar on mobile. The Table of Contents is designed for the \u003Cstrong\u003Emain content area\u003C/strong\u003E as a sticky collapsed bar that expands on click.\u003C/p\u003E"
          }
        }
      ]
    },
    {
      "contentTypeKey": "d5bfea49-0733-48ff-9ee0-d83c01a4cbf4",
      "key": "a1111111-1111-4111-8111-111111111113",
      "values": [
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Feature Title Filtering"
        },
        {
          "alias": "featurePropertyFeatureDescription",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "How the navigation picker decides which features to show and which to exclude"
        },
        {
          "alias": "richTextContent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Cp\u003EThe navigation picker is powered by a custom Contentment DataSource that scans the current page for all feature blocks across every block grid on the page. It applies a straightforward rule: \u003Cstrong\u003Eonly features that have a Feature Title set are offered in the picker\u003C/strong\u003E.\u003C/p\u003E\u003Cp\u003EThis design decision means that content-focused features like Rich Text Editors, FAQs, Tabs, and Code blocks naturally appear in the picker when they have titles, while utility features like standalone images, navigation blocks, and the page title block are excluded because they typically don\u0027t carry a Feature Title.\u003C/p\u003E\u003Cp\u003EThe beauty of this approach is that it gives content editors implicit control. If you want a feature to be available for in-page navigation, simply give it a Feature Title. If you want to exclude a feature that does have a title, you can either remove its title or simply deselect it in the navigation picker.\u003C/p\u003E"
          }
        }
      ]
    },
    {
      "contentTypeKey": "c345e5ce-768f-47e0-968a-e7859dbe0b07",
      "key": "158b5253-8371-4e7a-bb91-9e16a9d3c464",
      "values": []
    },
    {
      "contentTypeKey": "d5bfea49-0733-48ff-9ee0-d83c01a4cbf4",
      "key": "1bf0a936-42ed-452d-aff2-017e4ffb8a59",
      "values": [
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Human-Readable Fragment IDs"
        },
        {
          "alias": "featurePropertyFeatureDescription",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Clickable anchor links with slugified URLs instead of raw GUIDs"
        },
        {
          "alias": "richTextContent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Cp\u003EFeature blocks are identified by human-readable fragment IDs based on their title \u2014 for example \u003Ccode\u003E#introduction-a1b2\u003C/code\u003E rather than a raw GUID. A 4-character GUID suffix prevents collisions when two blocks share the same title on the same page.\u003C/p\u003E\u003Cp\u003EThe slug is generated by the \u003Ccode\u003ESlugHelper.ToSlug()\u003C/code\u003E static helper, which normalises the title to lowercase, replaces spaces with hyphens, strips special characters and diacritics, and appends the first 4 characters of the block\u0027s ContentKey.\u003C/p\u003E\u003Cp\u003EFeature headings are clickable links that update the browser URL with the fragment identifier. A small superscript \u003Ccode\u003E#\u003C/code\u003E appears on hover as a subtle hint. This makes it easy for visitors to copy and share direct links to specific sections.\u003C/p\u003E"
          }
        }
      ]
    },
    {
      "contentTypeKey": "d5bfea49-0733-48ff-9ee0-d83c01a4cbf4",
      "key": "038786dc-d8c9-47d5-ab04-6b395ddf73f7",
      "values": [
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Future Enhancements"
        },
        {
          "alias": "featurePropertyFeatureDescription",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Planned improvements and additional options"
        },
        {
          "alias": "richTextContent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Cp\u003EThe Navigation - In Page feature continues to evolve. Some of the enhancements we are considering include:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cstrong\u003EPer-feature allow toggle\u003C/strong\u003E \u2014 A setting on individual feature blocks to explicitly control whether they should be available to in-page navigation, giving editors more granular control beyond the Feature Title rule\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EShow/hide untitled blocks\u003C/strong\u003E \u2014 A toggle on the navigation settings to include or exclude blocks without a Feature Title from the picker\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003ENative sharing\u003C/strong\u003E \u2014 Integrating the Web Share API so visitors can share the current URL including the fragment identifier directly from the page\u003C/li\u003E\u003Cli\u003E\u003Cstrong\u003EElement type exclusion\u003C/strong\u003E \u2014 Code-level configuration to exclude certain feature types from ever appearing in the picker\u003C/li\u003E\u003C/ul\u003E"
          }
        }
      ]
    },
    {
      "contentTypeKey": "c4b3a613-0d2c-4470-8d06-f7efea52d6e0",
      "key": "b2fd4288-625d-49c1-b7ee-f38cf74087cd",
      "values": [
        {
          "alias": "featurePropertyNavigationInPageItems",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            "a1111111-1111-4111-8111-111111111109",
            "a1111111-1111-4111-8111-111111111111",
            "a1111111-1111-4111-8111-111111111113",
            "1bf0a936-42ed-452d-aff2-017e4ffb8a59",
            "038786dc-d8c9-47d5-ab04-6b395ddf73f7"
          ]
        }
      ]
    },
    {
      "contentTypeKey": "0708fc2f-92f1-4efc-a9d1-a755f66e6845",
      "key": "8883215f-5bdf-4c0f-b795-433d01204ad2",
      "values": []
    },
    {
      "contentTypeKey": "9aae0bbd-9a9b-4685-9b28-fe7fa4fbaaf8",
      "key": "e9210512-1ab7-472d-beb3-296b8d9d437d",
      "values": [
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "featureNavigationInPage.cshtml"
        },
        {
          "alias": "featurePropertyFeatureCode",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "@using Umbraco.Cms.Core.Models.Blocks\n@using Umbraco.Cms.Core.Models.PublishedContent\n@using Umbootstrap.Web.Helpers\n@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage\u003CBlockGridItem\u003E\n\n@{\n    var selectedKeys = Model.Content\n        .Value\u003CIEnumerable\u003Cstring\u003E\u003E(\u0022featurePropertyNavigationInPageItems\u0022);\n    var currentPage = Umbraco.AssignedContentItem;\n    var blockGrids = currentPage?.Properties\n        .Select(p =\u003E p.GetValue() as BlockGridModel)\n        .Where(g =\u003E g != null)\n        .Cast\u003CBlockGridModel\u003E()\n        .ToList() ?? new List\u003CBlockGridModel\u003E();\n}\n\n@{\n    var enableSticky = Model.Settings?\n        .Value\u003Cbool\u003E(\u0022featureSettingsEnableSticky\u0022) ?? false;\n    var uniqueId = Model.ContentKey.ToString(\u0022N\u0022);\n}\n\n@if (selectedKeys != null \u0026\u0026 selectedKeys.Any() \u0026\u0026 blockGrids.Count \u003E 0)\n{\n    var resolvedItems = new List\u003C(string title, string slug)\u003E();\n    foreach (var key in selectedKeys)\n    {\n        if (Guid.TryParse(key, out var contentKey))\n        {\n            var block = FindFeatureBlock(blockGrids, contentKey);\n            if (block != null)\n            {\n                var title = block.Content\n                    .Value\u003Cstring\u003E(\u0022featurePropertyFeatureTitle\u0022);\n                if (!string.IsNullOrWhiteSpace(title))\n                {\n                    var alias = block.Content.ContentType.Alias;\n                    resolvedItems.Add((title,\n                        SlugHelper.ToSlug(title, alias, contentKey)));\n                }\n            }\n        }\n    }\n    // ... desktop card, mobile offcanvas, ScrollSpy\n}"
        }
      ]
    }
  ],
