  <Properties>
    <contentGrid>
      <Value><![CDATA[{
  "contentData": [
    {
      "contentTypeKey": "f170b29c-338f-4ab8-a5c4-f72c90826f69",
      "key": "b3d5ef1d-2283-4622-bac8-100893b5e4b1",
      "values": []
    },
    {
      "contentTypeKey": "c345e5ce-768f-47e0-968a-e7859dbe0b07",
      "key": "9e8bbffd-d1d2-443d-bc31-1e61a58966f2",
      "values": []
    },
    {
      "contentTypeKey": "d5bfea49-0733-48ff-9ee0-d83c01a4cbf4",
      "key": "44e68c94-2661-4e78-8627-e2146c7ce1e1",
      "values": [
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "What It Does"
        },
        {
          "alias": "featurePropertyFeatureDescription",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Renders raw HTML directly on the page for embeds and custom markup"
        },
        {
          "alias": "richTextContent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Cp\u003EThe HTML feature gives content editors the ability to paste raw HTML that gets rendered directly on the page. This is essential for embedding third-party content like YouTube videos, social media widgets, maps, or any other service that provides an embed code.\u003C/p\u003E\u003Cp\u003EUnlike the Rich Text Editor which provides a WYSIWYG editing experience, the HTML feature accepts raw markup in a plain textarea. The content is output using \u003Ccode\u003EHtml.Raw()\u003C/code\u003E so it renders as actual HTML rather than escaped text.\u003C/p\u003E"
          }
        },
        {
          "alias": "featurePropertyFeatureSummary",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Only use Html.Raw() for trusted editor content, never for user-submitted input."
        }
      ]
    },
    {
      "contentTypeKey": "d5bfea49-0733-48ff-9ee0-d83c01a4cbf4",
      "key": "7652928a-7f4d-4146-961d-27ac56b00cce",
      "values": [
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "How It Works"
        },
        {
          "alias": "featurePropertyFeatureDescription",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "A simple view that outputs unescaped HTML from a textarea property"
        },
        {
          "alias": "richTextContent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Cp\u003EThe view is minimal \u2014 it uses \u003Ccode\u003EHtml.Raw()\u003C/code\u003E to output the contents of the \u003Ccode\u003EfeaturePropertyFeatureHTML\u003C/code\u003E textarea property without escaping. This means whatever HTML the editor pastes is rendered exactly as-is on the page.\u003C/p\u003E\u003Cp\u003EThe feature composes \u003Ccode\u003EfeatureComponentHTML\u003C/code\u003E which provides a single textarea property for the HTML markup. Combined with the standard feature compositions, editors can add a title and description above the embedded content to provide context.\u003C/p\u003E\u003Cp\u003EThe strongly-typed ModelsBuilder property is \u003Ccode\u003EModel.Content.FeaturePropertyFeatureHtml\u003C/code\u003E, which returns the raw string from the textarea.\u003C/p\u003E"
          }
        },
        {
          "alias": "featurePropertyFeatureSummary",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "For responsive embeds, wrap iframes in Bootstrap\u0027s ratio utility class (e.g. ratio ratio-16x9)."
        }
      ]
    },
    {
      "contentTypeKey": "6d7aa5eb-5edc-40c3-8013-2d4d4016f601",
      "key": "4924eb2f-fff4-41e4-90a2-2fbf0df2a56d",
      "values": [
        {
          "alias": "featurePropertyFeatureHTML",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "\u003Ciframe width=\u0022560\u0022 height=\u0022315\u0022 style=\u0022border-radius: 12px; overflow: hidden;\u0022 src=\u0022https://www.youtube.com/embed/CdVw5DK6olE\u0022 title=\u0022YouTube video player\u0022 frameborder=\u00220\u0022 allow=\u0022accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share\u0022 allowfullscreen\u003E\u003C/iframe\u003E"
        },
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Example: YouTube Embed"
        },
        {
          "alias": "featurePropertyFeatureDescription",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "A YouTube video embedded using the HTML feature"
        }
      ]
    },
