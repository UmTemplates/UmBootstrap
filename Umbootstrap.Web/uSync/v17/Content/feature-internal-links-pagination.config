            "ca72c7ef-6198-4f35-a33c-4aaf18e7dafc",
            "5756c891-4f5d-49b0-88e2-670ad3ff8cbf"
          ]
        }
      ]
    },
    {
      "contentTypeKey": "2ede97b0-9580-41cc-a029-bf041790c209",
      "key": "43e7822d-4de6-40dd-87be-5b72533cb5be",
      "values": []
    },
    {
      "contentTypeKey": "0708fc2f-92f1-4efc-a9d1-a755f66e6845",
      "key": "f77eb962-04ad-46d3-8f46-16d01e0df46e",
