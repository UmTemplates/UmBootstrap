      "values": []
    },
    {
      "contentTypeKey": "dfab01ba-2429-4be9-a894-3c6c4c49df94",
      "key": "a1d1fa43-e301-403c-b6bd-47b542d6d903",
      "values": []
    },
    {
      "contentTypeKey": "0708fc2f-92f1-4efc-a9d1-a755f66e6845",
      "key": "8d47db43-feb9-4fe5-8463-774c9667c45f",
      "values": []
    },
    {
      "contentTypeKey": "9aae0bbd-9a9b-4685-9b28-fe7fa4fbaaf8",
      "key": "eb9feaa2-4244-415d-b8cc-76e8e959047b",
      "values": [
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "featureInternalLinksPagination.cshtml"
        },
        {
          "alias": "featurePropertyFeatureCode",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "@using Microsoft.AspNetCore.Http\n@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage\u003CBlockGridItem\u003CFeatureInternalLinksPagination\u003E\u003E\n@inject IHttpContextAccessor HttpContextAccessor\n\n@{\n    Layout = \u0022_Layout_Features.cshtml\u0022;\n\n    var currentPage = UmbracoContext?.PublishedRequest?.PublishedContent;\n    var childPages = currentPage?.Children\u003CWebPage\u003E()?.ToArray() ?? [];\n\n    var pageSize = 3;\n    var queryPageValue = HttpContextAccessor.HttpContext?.Request.Query[\u0022page\u0022];\n    var currentPageNumber = string.IsNullOrWhiteSpace(queryPageValue)\n        ? 1 : Convert.ToInt32(queryPageValue);\n\n    var startItemIndex = currentPageNumber * pageSize - pageSize;\n\n    var displayedPages = childPages\n        .Where(x =\u003E x.IsVisible())\n        .OrderBy(x =\u003E x.SortOrder)\n        .Skip(startItemIndex)\n        .Take(pageSize);\n}\n\n// ... pagination nav \u002B card grid rendering"
        }
      ]
    }
  ],
