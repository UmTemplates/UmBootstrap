  <Properties>
    <contentGrid>
      <Value><![CDATA[{
  "contentData": [
    {
      "contentTypeKey": "f170b29c-338f-4ab8-a5c4-f72c90826f69",
      "key": "cc4f96a4-ccaa-4eef-b886-108666025060",
      "udi": null,
      "values": []
    },
    {
      "contentTypeKey": "c345e5ce-768f-47e0-968a-e7859dbe0b07",
      "key": "6c0b8b75-5078-4257-84f3-2a5a7f785335",
      "udi": null,
      "values": []
    },
    {
      "contentTypeKey": "d5bfea49-0733-48ff-9ee0-d83c01a4cbf4",
      "key": "94433f2e-eb5d-429d-b763-6bcc7a07de2c",
      "udi": null,
      "values": [
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "What It Does"
        },
        {
          "alias": "featurePropertyFeatureDescription",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The most commonly used feature for adding formatted text content"
        },
        {
          "alias": "richTextContent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Cp\u003EThe Rich Text Editor feature wraps Umbraco\u0027s built-in Tiptap rich text editor in the standard feature composition pattern. It gives content editors a familiar WYSIWYG editing experience for creating formatted text with headings, lists, links, images, and other HTML elements.\u003C/p\u003E\u003Cp\u003EThis is the workhorse feature of UmBootstrap \u2014 most content on a typical page is delivered through one or more Rich Text Editor blocks. Each block can have its own title, description, and summary via the shared feature compositions, with the rich text content forming the main body.\u003C/p\u003E"
          }
        },
        {
          "alias": "featurePropertyFeatureSummary",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "For readable line lengths, keep RTEs in areas up to 6 columns wide (WCAG 1.4.8 recommends 55\u201375 characters per line)."
        }
      ]
    },
    {
      "contentTypeKey": "d5bfea49-0733-48ff-9ee0-d83c01a4cbf4",
      "key": "aa1f7750-8ab7-4423-9216-01ec7711d997",
      "udi": null,
      "values": [
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "How It Works"
        },
        {
          "alias": "featurePropertyFeatureDescription",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "A minimal view that delegates everything to the feature layout and Umbraco\u0027s editor"
        },
        {
          "alias": "richTextContent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Cp\u003EThe view is one of the simplest in UmBootstrap \u2014 just a single line that outputs the \u003Ccode\u003ERichTextContent\u003C/code\u003E property. The feature layout (\u003Ccode\u003E_Layout_Features.cshtml\u003C/code\u003E) handles the title, description, and summary rendering, so the view only needs to render the rich text body.\u003C/p\u003E\u003Cp\u003EThe feature element type composes \u003Ccode\u003EfeatureComponentRichTextEditor\u003C/code\u003E which provides the \u003Ccode\u003ErichTextContent\u003C/code\u003E property using Umbraco\u0027s Tiptap editor. The editor toolbar and available formatting options are configured on the DataType in the Umbraco backoffice.\u003C/p\u003E\u003Cp\u003EThe view uses the strongly-typed ModelsBuilder model \u003Ccode\u003EFeatureRichTextEditor\u003C/code\u003E, so the property access is \u003Ccode\u003EModel.Content.RichTextContent\u003C/code\u003E rather than the untyped \u003Ccode\u003EModel.Content.Value(\u0022richTextContent\u0022)\u003C/code\u003E.\u003C/p\u003E"
          }
        },
        {
          "alias": "featurePropertyFeatureSummary",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": ""
        }
      ]
    },
    {
      "contentTypeKey": "c4b3a613-0d2c-4470-8d06-f7efea52d6e0",
      "key": "ec06dc8f-eb29-4fb1-8a38-906f43e47114",
