      "values": []
    },
    {
      "contentTypeKey": "0708fc2f-92f1-4efc-a9d1-a755f66e6845",
      "key": "6fb5dc6d-f50b-4f11-876d-daa2689a0d1e",
      "values": []
    },
    {
      "contentTypeKey": "9aae0bbd-9a9b-4685-9b28-fe7fa4fbaaf8",
      "key": "90e35c2c-d5fd-4a97-89cc-c5ad45174d08",
      "values": [
        {
          "alias": "featurePropertyFeatureCode",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage\u003CUmbraco.Cms.Core.Models.Blocks.BlockGridItem\u003CFeatureImage\u003E\u003E\n\n@{\n    Layout = \u0022_Layout_Features.cshtml\u0022;\n}\n\n@{\n    var typedMediaPickerSingle = Model.Content.Image;\n    if (typedMediaPickerSingle != null)\n    {\n        \u003Cimg src=\u0022@typedMediaPickerSingle.MediaUrl()\u0022\n             alt=\u0022\u0022\n             class=\u0022rounded-3\u0022\n             style=\u0022object-fit:cover; width:100%; height:100%;\u0022 /\u003E\n    } else {\n        \u003Cp\u003EMissing image\u003C/p\u003E\n    }\n}"
        },
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "featureImage.cshtml"
        }
      ]
