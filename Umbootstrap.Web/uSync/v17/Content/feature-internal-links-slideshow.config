    {
      "contentTypeKey": "9aae0bbd-9a9b-4685-9b28-fe7fa4fbaaf8",
      "key": "4d2d400a-a1fc-4231-932d-04de2c17251d",
      "values": [
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "featureInternalLinksSlideshow.cshtml"
        },
        {
          "alias": "featurePropertyFeatureCode",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage\u003CBlockGridItem\u003E\n\n@{\n    Layout = \u0022_Layout_Features.cshtml\u0022;\n    var maxItems = 5;\n    var guid = Guid.NewGuid().ToString();\n    var carouselId = \u0022carousel\u0022 \u002B guid;\n    var slides = Model.Content\n        .Value\u003CIEnumerable\u003CIPublishedContent\u003E\u003E(\u0022links\u0022)\n        ?.Take(maxItems).ToList()\n        ?? new List\u003CIPublishedContent\u003E();\n}\n\n\u003Cdiv id=\u0022@carouselId\u0022 class=\u0022carousel slide\u0022 data-bs-ride=\u0022carousel\u0022\u003E\n    \u003Cdiv class=\u0022carousel-indicators\u0022\u003E\n        @for (int i = 0; i \u003C slides.Count; i\u002B\u002B)\n        {\n            \u003Cbutton data-bs-target=\u0022#@carouselId\u0022 data-bs-slide-to=\u0022@i\u0022\n                    class=\u0022@(i == 0 ? \u0022active\u0022 : null)\u0022\u003E\u003C/button\u003E\n        }\n    \u003C/div\u003E\n    \u003Cdiv class=\u0022carousel-inner\u0022\u003E\n        @foreach (var item in slides) {\n            // ... carousel-item with thumbnail \u002B caption\n        }\n    \u003C/div\u003E\n    // ... prev/next controls\n\u003C/div\u003E"
        }
      ]
    }
  ],
