  <Properties>
    <contentGrid>
      <Value><![CDATA[{
  "contentData": [
    {
      "contentTypeKey": "f170b29c-338f-4ab8-a5c4-f72c90826f69",
      "key": "1fbd61f3-dd3c-4fda-860f-e7be3df11967",
      "values": []
    },
    {
      "contentTypeKey": "c345e5ce-768f-47e0-968a-e7859dbe0b07",
      "key": "ea5308d3-b139-446c-9f17-d56858f60080",
      "values": []
    },
    {
      "contentTypeKey": "d5bfea49-0733-48ff-9ee0-d83c01a4cbf4",
      "key": "3a4924b9-7fff-4ecb-91d7-637d99aeaf02",
      "values": [
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "What It Does"
        },
        {
          "alias": "featurePropertyFeatureDescription",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Displays selected pages as a Bootstrap carousel slideshow"
        },
        {
          "alias": "richTextContent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Cp\u003EThe Internal Links - Slideshow feature presents a set of editor-selected pages as a full-width Bootstrap carousel. Each slide shows the page\u0027s thumbnail image with a caption overlay containing the page title, description, and a link to the page.\u003C/p\u003E\u003Cp\u003EThis is ideal for hero sections, featured content highlights, or any situation where you want to showcase multiple pages in an engaging, rotating presentation. The carousel auto-plays and includes prev/next controls and slide indicators.\u003C/p\u003E"
          }
        },
        {
          "alias": "featurePropertyFeatureSummary",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The carousel displays up to 5 slides using Bootstrap\u0027s built-in carousel component with auto-play."
        }
      ]
    },
    {
      "contentTypeKey": "d5bfea49-0733-48ff-9ee0-d83c01a4cbf4",
      "key": "725a58ec-176b-4cf5-bdd9-840a44c708af",
      "values": [
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "How It Works"
        },
        {
          "alias": "featurePropertyFeatureDescription",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "A Multi Node Tree Picker rendered as a Bootstrap carousel with captions"
        },
        {
          "alias": "richTextContent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Cp\u003EThe view reads selected pages from the \u003Ccode\u003Elinks\u003C/code\u003E Multi Node Tree Picker property, limited to a maximum of 5 items. Each page\u0027s \u003Ccode\u003EpageThumbnail\u003C/code\u003E is rendered as a carousel slide image at 1296px width using \u003Ccode\u003EGetCropUrl()\u003C/code\u003E.\u003C/p\u003E\u003Cp\u003ECaptions are overlaid using Bootstrap\u0027s \u003Ccode\u003Ecarousel-caption\u003C/code\u003E class with a semi-transparent background (\u003Ccode\u003Ebg-body-secondary bg-opacity-75\u003C/code\u003E) for readability over the image. Each caption includes the page title as a stretched link, the description, and a slide counter.\u003C/p\u003E\u003Cp\u003EA unique carousel ID is generated using \u003Ccode\u003EGuid.NewGuid()\u003C/code\u003E to ensure multiple slideshows on the same page don\u0027t conflict with each other\u0027s Bootstrap data attributes.\u003C/p\u003E"
          }
        },
        {
          "alias": "featurePropertyFeatureSummary",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Captions are hidden on mobile using Bootstrap\u0027s d-none d-md-block utility classes."
        }
      ]
    },
    {
      "contentTypeKey": "c4b3a613-0d2c-4470-8d06-f7efea52d6e0",
      "key": "e7c12118-df1a-4145-8532-05c1baa3b559",
