          "segment": null,
          "value": "[{\u0022key\u0022:\u00220b36a0f1-d7db-43c3-afc5-4b09d7cf951c\u0022,\u0022mediaKey\u0022:\u00223ce997be-aa13-4390-939f-292337ac8936\u0022,\u0022mediaTypeAlias\u0022:\u0022Image\u0022,\u0022crops\u0022:[],\u0022focalPoint\u0022:null}]"
