      "values": []
    },
    {
      "contentTypeKey": "0708fc2f-92f1-4efc-a9d1-a755f66e6845",
      "key": "83bba97e-1155-484d-a5c7-3976038bc418",
      "values": []
    },
    {
      "contentTypeKey": "9aae0bbd-9a9b-4685-9b28-fe7fa4fbaaf8",
      "key": "61b27a94-8141-439c-8127-730b1658aead",
      "values": [
        {
          "alias": "featurePropertyFeatureCode",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage\u003CUmbraco.Cms.Core.Models.Blocks.BlockGridItem\u003E\n\n@{\n    Layout = \u0022_Layout_Features.cshtml\u0022;\n    // Get the current page\n    if(Umbraco.AssignedContentItem is not IContentHeadingDefault currentPage) return;\n}\n\n\u003Cdiv class=\u0022container p-3 mt-3 d-flex justify-content-center\u0022\u003E\n    \u003Cdiv class=\u0022w-75 text-center\u0022\u003E\n        \u003Ch1 class=\u0022display-1\u0022\u003E@currentPage.PageTitle\u003C/h1\u003E\n        \u003Cp class=\u0022lead\u0022\u003E@currentPage.PageDescription\u003C/p\u003E\n    \u003C/div\u003E\n\u003C/div\u003E"
        },
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "featurePageTitleDescription.cshtml"
        }
      ]
    },
    {
      "contentTypeKey": "dfab01ba-2429-4be9-a894-3c6c4c49df94",
      "key": "7931b02a-441c-44b6-b6e0-7f914018ae23",
      "values": [
