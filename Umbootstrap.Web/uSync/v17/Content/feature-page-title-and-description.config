          "segment": null,
          "value": "[{\u0022key\u0022:\u0022bb3730ac-c848-49a3-b4ff-9f0e154eef95\u0022,\u0022mediaKey\u0022:\u0022e27aa347-f148-422f-9b5b-ad71a0c42c6b\u0022,\u0022mediaTypeAlias\u0022:\u0022Image\u0022,\u0022crops\u0022:[],\u0022focalPoint\u0022:null}]"
        }
