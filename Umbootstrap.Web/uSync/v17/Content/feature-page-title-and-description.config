  <Properties>
    <contentGrid>
      <Value><![CDATA[{
  "contentData": [
    {
      "contentTypeKey": "f170b29c-338f-4ab8-a5c4-f72c90826f69",
      "key": "12002206-504e-47b4-a278-63a78a777f1c",
      "values": []
    },
    {
      "contentTypeKey": "c345e5ce-768f-47e0-968a-e7859dbe0b07",
      "key": "9fd7d862-db6f-424b-8f76-5e0aae6d06cd",
      "values": []
    },
    {
      "contentTypeKey": "d5bfea49-0733-48ff-9ee0-d83c01a4cbf4",
      "key": "5ab7219f-4d96-424a-b09f-189d24574467",
      "values": [
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "What It Does"
        },
        {
          "alias": "featurePropertyFeatureDescription",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Displays the current page\u0027s title and description as a prominent header"
        },
        {
          "alias": "richTextContent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Cp\u003EThe Page Title and Description feature reads the \u003Ccode\u003EpageTitle\u003C/code\u003E and \u003Ccode\u003EpageDescription\u003C/code\u003E properties from the current page and renders them as a centred hero-style header. The title appears as a large display heading and the description as a lead paragraph beneath it.\u003C/p\u003E\u003Cp\u003EThis feature is typically the first block on every page, placed inside a full-width layout12 at the top. It provides a consistent page header across the entire site without editors needing to re-enter the title and description in the content area.\u003C/p\u003E"
          }
        },
        {
          "alias": "featurePropertyFeatureSummary",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The title and description are entered on the Page Properties tab, not in the block editor."
        }
      ]
    },
    {
      "contentTypeKey": "d5bfea49-0733-48ff-9ee0-d83c01a4cbf4",
      "key": "12301061-3b99-4b51-bdf9-501b6537fa0a",
      "values": [
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "How It Works"
        },
        {
          "alias": "featurePropertyFeatureDescription",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Reads page-level properties rather than block content"
        },
        {
          "alias": "richTextContent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Cp\u003EUnlike most features which render their own content properties, the Page Title and Description feature reaches up to the current page using \u003Ccode\u003EUmbraco.AssignedContentItem\u003C/code\u003E and reads the \u003Ccode\u003EpageTitle\u003C/code\u003E and \u003Ccode\u003EpageDescription\u003C/code\u003E values directly.\u003C/p\u003E\u003Cp\u003EThe view casts the current page to \u003Ccode\u003EIContentHeadingDefault\u003C/code\u003E \u2014 a ModelsBuilder interface that provides strongly-typed access to the page title and description properties. If the page doesn\u0027t implement this interface, the feature renders nothing.\u003C/p\u003E\u003Cp\u003EThe feature uses \u003Ccode\u003E_Layout_Features.cshtml\u003C/code\u003E as its layout, giving it the standard feature wrapper. However, the feature\u0027s own title is typically left empty since the page heading itself serves as the visual header.\u003C/p\u003E"
          }
        },
        {
          "alias": "featurePropertyFeatureSummary",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "The pageTitleShort property provides a shorter version used in navigation menus, keeping hero headings expressive while menu items stay concise."
        }
      ]
    },
    {
      "contentTypeKey": "c4b3a613-0d2c-4470-8d06-f7efea52d6e0",
      "key": "cc5822e7-5b06-4c2f-865f-d28d576230d6",
      "values": [
        {
          "alias": "featurePropertyNavigationInPageItems",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": [
            "5ab7219f-4d96-424a-b09f-189d24574467",
            "12301061-3b99-4b51-bdf9-501b6537fa0a"
          ]
        }
      ]
    },
    {
