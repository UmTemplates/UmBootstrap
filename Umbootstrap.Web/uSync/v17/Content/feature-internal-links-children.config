    {
      "contentTypeKey": "0708fc2f-92f1-4efc-a9d1-a755f66e6845",
      "key": "6aa4b77f-0ea3-44d3-8111-de499147476e",
      "values": []
    },
    {
      "contentTypeKey": "9aae0bbd-9a9b-4685-9b28-fe7fa4fbaaf8",
      "key": "044fd322-6178-4549-b32d-aa3a88a84741",
      "values": [
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "featureInternalLinksChildren.cshtml"
        },
        {
          "alias": "featurePropertyFeatureCode",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage\u003CBlockGridItem\u003CFeatureInternalLinksChildren\u003E\u003E\n@inject IWebHostEnvironment WebHostEnvironment\n\n@{\n    Layout = \u0022_Layout_Features.cshtml\u0022;\n    var children = UmbracoContext?.PublishedRequest?.PublishedContent?.Children\u003CWebPage\u003E();\n}\n\n@if (children != null \u0026\u0026 children.Any())\n{\n    \u003Cdiv class=\u0022grid\u0022\u003E\n        @foreach (var childPage in children)\n        {\n            var thumbnail = childPage.PageThumbnail;\n            \u003Cdiv class=\u0022g-col-12 g-col-md-6 g-col-lg-4\u0022\u003E\n                \u003Cdiv class=\u0022card h-100 shadow\u0022\u003E\n                    @if (thumbnail != null)\n                    {\n                        // SVG: inline for dark mode support\n                        // Other: use GetCropUrl for optimised image\n                    }\n                    \u003Cdiv class=\u0022card-body text-center\u0022\u003E\n                        \u003Ch3 class=\u0022card-title pb-1\u0022\u003E\n                            \u003Ca class=\u0022stretched-link\u0022 href=\u0022@childPage.Url()\u0022\u003E\n                                @childPage.PageTitle\n                            \u003C/a\u003E\n                        \u003C/h3\u003E\n                        \u003Cp class=\u0022card-text pb-2\u0022\u003E@childPage.PageDescription\u003C/p\u003E\n                    \u003C/div\u003E\n                \u003C/div\u003E\n            \u003C/div\u003E\n        }\n    \u003C/div\u003E\n}"
        }
      ]
    }
  ],
