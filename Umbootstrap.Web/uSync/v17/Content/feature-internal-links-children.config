          "value": "[{\u0022key\u0022:\u00220b70ba14-17d3-4ffc-b6b6-e130df7e7b6a\u0022,\u0022mediaKey\u0022:\u0022388c7ddd-9acd-4d1f-a473-57054c9d4a6d\u0022,\u0022mediaTypeAlias\u0022:\u0022Image\u0022,\u0022crops\u0022:[],\u0022focalPoint\u0022:null}]"
