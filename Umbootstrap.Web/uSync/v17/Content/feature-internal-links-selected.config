    {
      "contentTypeKey": "9aae0bbd-9a9b-4685-9b28-fe7fa4fbaaf8",
      "key": "534493a2-77d7-4955-856e-f469826db126",
      "values": [
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "featureInternalLinks.cshtml"
        },
        {
          "alias": "featurePropertyFeatureCode",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage\u003CBlockGridItem\u003CFeatureInternalLinks\u003E\u003E\n\n@{\n    Layout = \u0022_Layout_Features.cshtml\u0022;\n    var typedMultiNodeTreePicker = Model.Content.Links?.Cast\u003CWebPage\u003E();\n}\n\n@if (typedMultiNodeTreePicker != null)\n{\n    \u003Cdiv class=\u0022grid\u0022\u003E\n        @foreach (var item in typedMultiNodeTreePicker)\n        {\n            var pageThumbnail = item.PageThumbnail;\n            \u003Cdiv class=\u0022g-col-12 g-col-md-6 g-col-lg-4\u0022\u003E\n                \u003Cdiv class=\u0022card h-100 shadow\u0022\u003E\n                    @if (pageThumbnail is not null)\n                    {\n                        \u003Cimg src=\u0022@(pageThumbnail.GetCropUrl(width: 480))\u0022\n                             class=\u0022card-img-top\u0022 alt=\u0022...\u0022\u003E\n                    }\n                    \u003Cdiv class=\u0022card-body text-center\u0022\u003E\n                        \u003Ch3 class=\u0022card-title pb-1\u0022\u003E\n                            \u003Ca class=\u0022stretched-link\u0022\n                               href=\u0022@item.Url()\u0022\u003E@item.PageTitle\u003C/a\u003E\n                        \u003C/h3\u003E\n                        \u003Cp class=\u0022card-text pb-2\u0022\u003E@item.PageDescription\u003C/p\u003E\n                    \u003C/div\u003E\n                \u003C/div\u003E\n            \u003C/div\u003E\n        }\n    \u003C/div\u003E\n}"
        }
      ]
    }
  ],
