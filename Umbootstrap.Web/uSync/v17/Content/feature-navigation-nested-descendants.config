<?xml version="1.0" encoding="utf-8"?>
<Content Key="118b9c7c-fe77-41e1-b3ac-fc3edffd1874" Alias="Feature - Navigation - Nested Descendants" Level="3">
  <Info>
    <Parent Key="fbb2a257-2f19-452d-b7ad-d31ab8fd0fa2">Features</Parent>
