  <Properties>
    <contentGrid>
      <Value><![CDATA[{
  "contentData": [
    {
      "contentTypeKey": "f170b29c-338f-4ab8-a5c4-f72c90826f69",
      "key": "efcce15f-4e05-4e21-84c6-b85bb8219f70",
      "values": []
    },
    {
      "contentTypeKey": "c345e5ce-768f-47e0-968a-e7859dbe0b07",
      "key": "8f92ed86-11b6-48b3-8faf-afe184080114",
      "values": []
    },
    {
      "contentTypeKey": "d5bfea49-0733-48ff-9ee0-d83c01a4cbf4",
      "key": "614457c5-2b71-4b08-8db4-440bae81bcf9",
      "values": [
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "What It Does"
        },
        {
          "alias": "featurePropertyFeatureDescription",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Displays code snippets with syntax preservation in a pre-formatted block"
        },
        {
          "alias": "richTextContent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Cp\u003EThe Code feature lets content editors paste code snippets that are displayed in a pre-formatted block on the page. The code is rendered inside \u003Ccode\u003E\u0026lt;pre\u0026gt;\u0026lt;code\u0026gt;\u003C/code\u003E tags, which preserves whitespace, indentation, and line breaks exactly as entered.\u003C/p\u003E\u003Cp\u003EThis is particularly useful for documentation pages, tutorials, and developer-facing content where showing actual code examples is essential. Every feature page in UmBootstrap uses a Code block at the bottom to show the Razor view source.\u003C/p\u003E"
          }
        },
        {
          "alias": "featurePropertyFeatureSummary",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "UmBootstrap includes highlight.js with the github-dark theme and a copy button plugin, loaded from CDN."
        }
      ]
    },
    {
      "contentTypeKey": "d5bfea49-0733-48ff-9ee0-d83c01a4cbf4",
      "key": "d4ed68b1-4b2a-4f02-866b-e070e0c09e04",
      "values": [
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "How It Works"
        },
        {
          "alias": "featurePropertyFeatureDescription",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "A textarea property rendered inside pre and code tags"
        },
        {
          "alias": "richTextContent",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "Layout": {}
            },
            "markup": "\u003Cp\u003EThe view wraps the \u003Ccode\u003EfeaturePropertyFeatureCode\u003C/code\u003E textarea content in \u003Ccode\u003E\u0026lt;pre\u0026gt;\u0026lt;code\u0026gt;\u003C/code\u003E tags. Unlike the HTML feature which uses \u003Ccode\u003EHtml.Raw()\u003C/code\u003E, the Code feature outputs the content as plain text \u2014 HTML tags and special characters are escaped automatically by Razor, so the code is displayed rather than executed.\u003C/p\u003E\u003Cp\u003EThe feature composes \u003Ccode\u003EfeatureComponentCode\u003C/code\u003E which provides a single textarea property. Combined with the standard feature title composition, editors can label each code block with a filename or description.\u003C/p\u003E\u003Cp\u003EThe strongly-typed ModelsBuilder property is \u003Ccode\u003EModel.Content.FeaturePropertyFeatureCode\u003C/code\u003E. Because Razor escapes the output by default, no special sanitisation is needed.\u003C/p\u003E"
          }
        },
        {
          "alias": "featurePropertyFeatureSummary",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Use the feature title to show the filename \u2014 developers can then find the corresponding file in the project."
        }
      ]
    },
    {
      "contentTypeKey": "9aae0bbd-9a9b-4685-9b28-fe7fa4fbaaf8",
      "key": "3ab77f72-a129-446e-b7e0-b6f548706646",
      "values": [
        {
          "alias": "featurePropertyFeatureCode",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "@{\n    // Example: Reading feature settings\n    bool hasSettings = Model.Settings != null;\n    string colorLabel = null;\n\n    if (hasSettings)\n    {\n        var backgroundColour = Model.Settings\n            .Value\u003CColorPickerValueConverter.PickedColor\u003E\n            (\u0022featureSettingsColourPicker\u0022);\n        colorLabel = backgroundColour?.Label;\n    }\n}"
        },
        {
          "alias": "featurePropertyFeatureTitle",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": "Example: Reading Feature Settings"
        }
      ]
    },
    {
