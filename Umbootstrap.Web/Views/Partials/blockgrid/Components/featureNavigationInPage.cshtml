@using Umbraco.Cms.Core.Models.Blocks
@using Umbraco.Cms.Core.Models.PublishedContent
@using Umbootstrap.Web.Helpers
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Umbraco.Cms.Core.Models.Blocks.BlockGridItem>

@{
    var selectedKeys = Model.Content.Value<IEnumerable<string>>("featurePropertyNavigationInPageItems");
    var currentPage = Umbraco.AssignedContentItem;
    var blockGrids = currentPage?.Properties
        .Select(p => p.GetValue() as BlockGridModel)
        .Where(g => g != null)
        .Cast<BlockGridModel>()
        .ToList() ?? new List<BlockGridModel>();
}

@{
    var enableSticky = Model.Settings?.Value<bool>("featureSettingsEnableSticky") ?? false;
    var uniqueId = Model.ContentKey.ToString("N");
}

@if (selectedKeys != null && selectedKeys.Any() && blockGrids.Count > 0)
{
    // Resolve blocks once for reuse
    var resolvedItems = new List<(string title, string slug)>();
    foreach (var key in selectedKeys)
    {
        if (Guid.TryParse(key, out var contentKey))
        {
            var block = FindFeatureBlock(blockGrids, contentKey);
            if (block != null)
            {
                var title = block.Content.Value<string>("featurePropertyFeatureTitle");
                if (!string.IsNullOrWhiteSpace(title))
                {
                    var alias = block.Content.ContentType.Alias;
                    resolvedItems.Add((title, SlugHelper.ToSlug(title, alias, contentKey)));
                }
            }
        }
    }

    // Desktop: card with sticky nav (hidden on mobile)
    <nav id="nav-in-page-@uniqueId" class="card @(enableSticky ? "sticky-nav" : "") d-none d-lg-block" aria-label="Jump to section">
        <header class="card-header">
            <h2 class="card-title mb-0">On this page</h2>
        </header>
        <ul class="list-group list-group-flush nav">
            @foreach (var item in resolvedItems)
            {
                <li>
                    <a href="#@item.slug" class="list-group-item-action list-group-item">@item.title</a>
                </li>
            }
        </ul>
    </nav>

    // Mobile: fixed bottom bar + offcanvas (hidden on desktop)
    <div class="d-lg-none">
        <div class="nav-mobile-bar" data-bs-toggle="offcanvas" data-bs-target="#offcanvas-@uniqueId" aria-controls="offcanvas-@uniqueId">
            <h2 class="mb-0">On this page</h2>
            <button class="navbar-toggler" type="button" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
        </div>

        <div class="offcanvas offcanvas-bottom" tabindex="-1" id="offcanvas-@uniqueId" aria-labelledby="offcanvas-label-@uniqueId">
            <div class="offcanvas-header">
                <h2 class="offcanvas-title" id="offcanvas-label-@uniqueId">On this page</h2>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            </div>
            <div class="offcanvas-body">
                <nav id="nav-in-page-mobile-@uniqueId" aria-label="Jump to section">
                    <ul class="list-group list-group-flush nav">
                        @foreach (var item in resolvedItems)
                        {
                            <li>
                                <a href="#@item.slug" class="list-group-item-action list-group-item">@item.title</a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Desktop ScrollSpy
            var navId = 'nav-in-page-@uniqueId';
            var navEl = document.getElementById(navId);
            if (navEl) {
                new bootstrap.ScrollSpy(document.body, {
                    target: '#' + navId,
                    rootMargin: '0px 0px -75%'
                });
            }

            // Mobile ScrollSpy
            var mobileNavId = 'nav-in-page-mobile-@uniqueId';
            var mobileNavEl = document.getElementById(mobileNavId);
            if (mobileNavEl) {
                new bootstrap.ScrollSpy(document.body, {
                    target: '#' + mobileNavId,
                    rootMargin: '0px 0px -75%'
                });
            }

            // Mobile offcanvas: scroll to section then close
            var offcanvasEl = document.getElementById('offcanvas-@uniqueId');
            if (offcanvasEl) {
                var bsOffcanvas = bootstrap.Offcanvas.getOrCreateInstance(offcanvasEl);
                offcanvasEl.querySelectorAll('a[href^="#"]').forEach(function (link) {
                    link.addEventListener('click', function (e) {
                        e.preventDefault();
                        var target = document.querySelector(this.getAttribute('href'));
                        if (target) {
                            target.scrollIntoView({ behavior: 'smooth' });
                        }
                        bsOffcanvas.hide();
                    });
                });
            }
        });
    </script>
}

@functions {
    private static BlockGridItem? FindFeatureBlock(List<BlockGridModel> grids, Guid contentKey)
    {
        foreach (var grid in grids)
        {
            foreach (var block in grid)
            {
                if (block.ContentKey == contentKey)
                    return block;

                foreach (var area in block.Areas)
                {
                    foreach (var nested in area)
                    {
                        if (nested.ContentKey == contentKey)
                            return nested;
                    }
                }
            }
        }
        return null;
    }
}
