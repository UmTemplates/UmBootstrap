@using Umbraco.Cms.Core.Models.Blocks
@using Umbraco.Cms.Core.Models.PublishedContent
@using Umbootstrap.Web.Helpers
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Umbraco.Cms.Core.Models.Blocks.BlockGridItem>

@{
    var currentPage = Umbraco.AssignedContentItem;
    var blockGrids = currentPage?.Properties
        .Select(p => p.GetValue() as BlockGridModel)
        .Where(g => g != null)
        .Cast<BlockGridModel>()
        .ToList() ?? new List<BlockGridModel>();

    var uniqueId = Model.ContentKey.ToString("N");
    var tocContentKey = Model.ContentKey;
    var enableSticky = Model.Settings?.Value<bool>("featureSettingsEnableSticky") ?? false;

    // Find sibling blocks in the same area as this TOC block
    var siblingItems = new List<(string title, string slug)>();
    foreach (var grid in blockGrids)
    {
        foreach (var layoutBlock in grid)
        {
            foreach (var area in layoutBlock.Areas)
            {
                var areaBlocks = area.ToList();
                var tocInThisArea = areaBlocks.Any(b => b.ContentKey == tocContentKey);
                if (tocInThisArea)
                {
                    foreach (var block in areaBlocks)
                    {
                        if (block.ContentKey == tocContentKey)
                            continue;

                        var alias = block.Content.ContentType.Alias;
                        if (!alias.StartsWith("feature", StringComparison.OrdinalIgnoreCase))
                            continue;

                        var title = block.Content.Value<string>("featurePropertyFeatureTitle");
                        if (!string.IsNullOrWhiteSpace(title))
                        {
                            siblingItems.Add((title, SlugHelper.ToSlug(title, alias, block.ContentKey)));
                        }
                    }
                    break;
                }
            }
            if (siblingItems.Any()) break;
        }
        if (siblingItems.Any()) break;
    }
}

@if (siblingItems.Any())
{
    <nav id="nav-toc-@uniqueId" class="card @(enableSticky ? "nav-toc-sticky" : "")" aria-label="Table of contents">
        <div class="card-header" role="button" data-bs-toggle="collapse" data-bs-target="#toc-@uniqueId" aria-expanded="false" aria-label="Toggle table of contents" style="cursor: pointer;">
            <nav class="navbar p-0">
                <h2 class="card-title mb-0">On this page</h2>
                <button class="navbar-toggler" type="button" tabindex="-1">
                    <span class="navbar-toggler-icon"></span>
                </button>
            </nav>
        </div>
        <div class="collapse" id="toc-@uniqueId">
            <ul class="list-group list-group-flush nav">
                @foreach (var item in siblingItems)
                {
                    <li>
                        <a href="#@item.slug" class="list-group-item-action list-group-item">@item.title</a>
                    </li>
                }
            </ul>
        </div>
    </nav>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var navId = 'nav-toc-@uniqueId';
            var navEl = document.getElementById(navId);

            // Set --toc-height for scroll-margin-top calculations
            if (navEl) {
                var tocHeight = navEl.querySelector('.card-header').offsetHeight;
                document.documentElement.style.setProperty('--toc-height', tocHeight + 'px');

                // Detect when TOC becomes sticky and add shadow
                var sentinel = document.createElement('div');
                sentinel.style.height = '1px';
                sentinel.style.marginBottom = '-1px';
                navEl.parentNode.insertBefore(sentinel, navEl);
                var observer = new IntersectionObserver(function (entries) {
                    navEl.classList.toggle('is-stuck', !entries[0].isIntersecting);
                }, { threshold: 0 });
                observer.observe(sentinel);
            }

            new bootstrap.ScrollSpy(document.body, {
                target: '#' + navId,
                rootMargin: '0px 0px -75%'
            });

            // Auto-collapse on link click, scroll after collapse finishes
            var collapseId = 'toc-@uniqueId';
            var collapseEl = document.getElementById(collapseId);
            if (collapseEl) {
                var bsCollapse = bootstrap.Collapse.getOrCreateInstance(collapseEl, { toggle: false });
                collapseEl.querySelectorAll('a').forEach(function (link) {
                    link.addEventListener('click', function (e) {
                        e.preventDefault();
                        var targetId = this.getAttribute('href');
                        bsCollapse.hide();
                        collapseEl.addEventListener('hidden.bs.collapse', function onHidden() {
                            collapseEl.removeEventListener('hidden.bs.collapse', onHidden);
                            var target = document.querySelector(targetId);
                            if (target) {
                                target.scrollIntoView({ behavior: 'instant' });
                            }
                        });
                    });
                });
            }
        });
    </script>
}
